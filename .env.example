# =============================================================================
# mentorship-backend — Docker Compose
# =============================================================================
# Full stack (needs sibling repos):
#   ../mentorship-frontend-master/frontend
#   ../mentorship-frontend-admin
#
#   docker-compose up -d --build
# API + DB only: make compose-api-up
#
# Layout on disk (example):
#   ~/mentorship-backend/
#   ~/mentorship-frontend-master/
#   ~/mentorship-frontend-admin/
# See ~/MENTORSHIP.md

# --- Host ports (published to your machine) ---
FRONTEND_PORT=5173
ADMIN_PORT=5174
HTTP_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379
# If local Postgres already uses 5432, set POSTGRES_PORT=5433 for Docker only.

# --- PostgreSQL (service name: postgres) ---
POSTGRES_USER=mentorship
POSTGRES_PASSWORD=mentorship
POSTGRES_DB=mentorship
# Used by go run on host only (not substituted into docker-compose services):
# DATABASE_URL=postgres://mentorship:mentorship@127.0.0.1:5432/mentorship?sslmode=disable
DATABASE_URL=postgres://mentorship:mentorship@postgres:5432/mentorship?sslmode=disable
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=2
DATABASE_MAX_CONN_LIFETIME=30m
DATABASE_MAX_CONN_IDLE_TIME=5m
DATABASE_HEALTH_TIMEOUT=2s

# --- Redis (required for backend /health/ready; service name: redis) ---
# Host dev: REDIS_ADDR=127.0.0.1:6379
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_HEALTH_TIMEOUT=2s

# --- Backend API (service name: backend) ---
APP_ENV=development
LOG_LEVEL=debug
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s

JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Frontend image build args (baked at docker compose build) ---
VITE_API_BASE_URL=/api/v1
VITE_USE_MOCK=false

# =============================================================================
# Local development WITHOUT Docker (do not copy Docker DATABASE_URL to shell)
# =============================================================================
# Infra only (optional): docker-compose up -d postgres redis
#
# Backend (this repo):
#   export DATABASE_URL='postgres://mentorship:mentorship@127.0.0.1:5432/mentorship?sslmode=disable'
#   export REDIS_ADDR='127.0.0.1:6379'
#   export HTTP_PORT=8081
#   export JWT_SECRET='dev-local-secret'
#   go run ./cmd/api
#
# Frontends — отдельные репозитории (корень = Vite-проект):
#   cd ../mentorship-frontend-master && npm run dev   # :5173
#   cd ../mentorship-frontend-admin && npm run dev    # :5174
#
# Migrations: make migrate-up
# Dev users:  psql ... -f seeds/001_dev_user.sql -f seeds/002_student_buddy.sql

# =============================================================================
# Production deploy (infra only — change before go-live)
# =============================================================================
# APP_ENV=production
# LOG_LEVEL=info
# JWT_SECRET=<long-random-secret>
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# Use strong POSTGRES_PASSWORD; do not expose POSTGRES_PORT/REDIS_PORT publicly.
